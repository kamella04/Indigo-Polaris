# Copy to .env and fill in your values. Never commit .env!

# Email (Gmail example - use App Password, not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_FROM_EMAIL=your-email@gmail.com

# YouTube Data API v3 - get key at https://console.cloud.google.com/
YOUTUBE_API_KEY=

# Instagram Graph API - requires Meta Developer App
INSTAGRAM_ACCESS_TOKEN=

# Facebook Graph API
FACEBOOK_ACCESS_TOKEN=

# Spotify - removed for now, may revise after 1M monthly listeners
